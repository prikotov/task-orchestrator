{
    "name": "prikotov/task-orchestrator",
    "description": "TasK Agent Orchestrator — chain-based AI agent orchestration with retry, circuit breaker, quality gates, dynamic loops",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/lock": "^8.0",
        "symfony/process": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "prikotov/coding-standard": "^0.0",
        "prikotov/todo-md": "^0.0",
        "prikotov/git-workflow": "^0.0",
        "vimeo/psalm": "^6.16",
        "psalm/plugin-symfony": "^5.3",
        "deptrac/deptrac": "^2.0"
    },
    "repositories": [
        {"type": "vcs", "url": "https://github.com/prikotov/coding-standard"},
        {"type": "vcs", "url": "https://github.com/prikotov/todo-md"},
        {"type": "vcs", "url": "https://github.com/prikotov/git-workflow"}
    ],
    "autoload": {
        "psr-4": {
            "TaskOrchestrator\\Common\\": "src/",
            "TaskOrchestrator\\Console\\": "apps/console/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TaskOrchestrator\\Tests\\": "tests/",
            "TaskOrchestrator\\Console\\Tests\\": "apps/console/tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
